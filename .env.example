# ── 复制此文件为 .env 并按需修改 ──────────────────────────

# MySQL root 密码（仅 MySQL 容器初始化时使用）
MYSQL_ROOT_PASSWORD=quizapp2026

# 应用连接 MySQL 的普通账号
MYSQL_USER=quizuser
MYSQL_PASSWORD=quizpass

# 数据库名（生产和测试可使用不同的库名，MySQL 会自动创建）
# 生产环境：MYSQL_DB=quiz_app
# 测试环境：MYSQL_DB=quiz_test
MYSQL_DB=quiz_app

# JWT 签名密钥（生产环境务必修改为随机长字符串）
JWT_SECRET=change_me_in_production

# 应用对外暴露的端口
# 生产环境：APP_PORT=18084
# 测试环境：APP_PORT=18082
APP_PORT=18084

# 静态文件 volume 名（生产和测试建议使用不同名称）
# 生产环境：STATIC_VOLUME=static_prod
# 测试环境：STATIC_VOLUME=static_test
STATIC_VOLUME=static_prod
