# ── 复制此文件为 .env 并按需修改 ──────────────────────────

# MySQL root 密码（仅 MySQL 容器初始化时使用）
MYSQL_ROOT_PASSWORD=quizapp2026

# 应用连接 MySQL 的普通账号（推荐不使用 root）
MYSQL_USER=quizuser
MYSQL_PASSWORD=quizpass
MYSQL_DB=quiz_app

# JWT 签名密钥（生产环境务必修改为随机长字符串）
JWT_SECRET=change_me_in_production

# 应用对外暴露的端口（默认 8080）
APP_PORT=8080
